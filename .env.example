# TuneSet 配置文件示例
# 复制为 .env 后按需修改；标 <改> 的为必改项

# ===== 应用 =====
# 运行环境：development / production（production 下强制校验密钥类配置）
APP_ENV=development
# JWT/会话签名密钥，生产必须改为长随机串
SECRET_KEY=<改>

# ===== 数据库 =====
# SQLite 数据库文件路径
SQLITE_PATH=./data/tuneset.db

# ===== Redis =====
# Redis 连接地址（Celery 队列 + LangGraph checkpoint + 限流计数共用）
REDIS_URL=redis://redis:6379/0

# ===== JWT =====
# JWT 签名算法
JWT_ALGORITHM=HS256
# access token 有效期（分钟），1440 = 1 天
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
# refresh token 有效期（天），30 = 30 天
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ===== 注册 =====
# 是否开放公开注册（false = 仅邀请码注册）
PUBLIC_REGISTRATION_ENABLED=false
# 注册是否必须邀请码
INVITE_CODE_REQUIRED=true

# ===== 超管 =====
# 超管邮箱（启动时创建；已存在则跳过；改密后重启会更新哈希）
SUPERADMIN_EMAIL=admin@tuneset.dev
# 超管密码（改后重启后端生效；生产必须改为强密码）
SUPERADMIN_PASSWORD=<改>

# ===== 前端（compose 层）=====
# compose 宿主映射端口（容器内 nginx 固定 80）
FRONTEND_PORT=80

# ===== 我喜欢推送 =====
# "我喜欢"列表推送/缓存刷新间隔（秒），默认 300（5 分钟）
FAV_PUSH_INTERVAL=300

# ===== 日志 =====
# 日志文件路径（容器内，docker volume 挂载到宿主机 ./logs）
LOG_FILE=/app/logs/app.log
# 单个日志文件最大字节（超出 rotation），默认 10MB
LOG_MAX_BYTES=10485760
# 保留旧日志文件数
LOG_BACKUP_COUNT=5

# ===== 限流 =====
# 用户每日 AI 调用上限
RATE_LIMIT_USER_DAILY=10
# IP 每小时请求上限
RATE_LIMIT_IP_HOURLY=100
# 分类任务最小间隔（秒），防刷
RATE_LIMIT_CLASSIFY_INTERVAL=30
# 单次分类最大歌曲数
CLASSIFY_MAX_SONGS=2000
# 单批 AI 分类上限（分批分类用）
CLASSIFY_BATCH_SIZE=200
# 分类最大轮次（多轮 HITL，最多 5 轮）
CLASSIFY_MAX_ITERATIONS=5

# ===== AI =====
# AI 协议：openai / anthropic
AI_PROTOCOL=openai
# AI API 基址
AI_BASE_URL=https://api.openai.com/v1
# AI API 密钥
AI_API_KEY=<改>
# AI 模型名
AI_MODEL=gpt-4o-mini

# ===== Celery =====
# Celery broker（任务队列）
CELERY_BROKER_URL=redis://redis:6379/1
# Celery result backend（结果存储）
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===== LangSmith（可选）=====
# 是否启用 LangSmith 追踪
LANGSMITH_TRACING=false
# LangSmith API 密钥（可选）
LANGSMITH_API_KEY=

# ===== 前端构建期（VITE_）=====
# vite 构建期注入客户端；仅 VITE_ 前缀变量进入 bundle，后端密钥不会泄露
# API 基址（nginx 反代下用相对路径 /api）
VITE_API_BASE_URL=/api
# 扫码状态轮询间隔（毫秒）
VITE_QR_POLL_INTERVAL=2000
# 分类最大轮次（应与后端 CLASSIFY_MAX_ITERATIONS 对齐）
VITE_CLASSIFY_MAX_ITERATIONS=5
